---
groups:
  - name: IPSec-alerts
    rules:

      - alert: IKEDown
        expr: strongswan_ike_state != 1
        for: 1m
        labels:
          severity: critical
          kind: ipsec_health
        annotations:
          summary: "IKE tunnel {{ $labels.name }} is not established"
          description: "Check peer reachability, credentials, phase1 config, and strongSwan logs."

      - alert: ChildSADown
        expr: (strongswan_sa_state != 1) and  on(ike_id) (label_replace(strongswan_ike_state,"ike_id", "$1", "uniqueid", "(.*)") == 1)
        for: 1m
        labels:
          severity: critical
          kind: ipsec_health
        annotations:
          summary: "Child SA down"
          description: "Traffic tunnel not established (strongswan_sa_state) while IKE is up. Check phase2 proposals, routing, and policy mismatches."

      - alert: IKEFlapping
        expr: count without (uniqueid) (last_over_time(strongswan_ike_established_second[10m])) > 2
        for: 2m
        labels:
          severity: warning
          kind: ipsec_health
        annotations:
          summary: "IKE flapping on {{ $labels.instance }}"
          description: "Tunnel {{ $labels.name }} has reset its connection {{ $value }} times in the last 10 minutes. Investigate network instability, DPD settings, or mismatched lifetimes."

      - alert: ChildSAFlapping
        expr: count without (child_id,ike_id) (last_over_time(strongswan_sa_established_second[10m])) > 1 and strongswan_ike_state == 1
        for: 2m
        labels:
          severity: warning
          kind: ipsec_health
        annotations:
          summary: "Child SA flapping (strongswan_sa_established_second resets)"
          description: "Child SA unstable. Check rekey timers, packet drops, and crypto mismatches."

      - alert: IKERekeyIntervalTooLong
        expr: (strongswan_ike_established_second + strongswan_ike_rekey_second) > 28800
        for: 5m
        labels:
          severity: warning
          kind: ipsec_security_condition
        annotations:
          summary: "IKE rekey interval exceeds 8 hours"
          description: "Derived IKE rekey interval is greater than 8h. This may violate security policy. Check lifetime/rekey configuration on both peers."

      - alert: SARekeyIntervalTooLong
        expr: (strongswan_sa_established_second + strongswan_sa_rekey_second) > 3600
        for: 5m
        labels:
          severity: warning
          kind: ipsec_security_condition
        annotations:
          summary: "Child SA rekey interval exceeds policy"
          description: "Derived Child SA rekey interval is higher than expected. Verify SA lifetime and rekey timers."

      - alert: NoChildSA
        expr: (strongswan_ike_children == 0) and on(name,uniqueid) (strongswan_ike_state == 1)
        for: 1m
        labels:
          severity: critical
          kind: ipsec_health
        annotations:
          summary: "No child SAs (strongswan_ike_children == 0)"
          description: "IKE established but no active tunnels. Verify traffic selectors, policies, and routing."

      - alert: NoInboundTraffic
        expr: sum by (ike_id, ike_name) ((rate(strongswan_sa_bytes_inbound[5m]) < 1) and on(child_id, ike_id) (strongswan_sa_state == 1)) == count by (ike_id, ike_name) ( (strongswan_sa_state == 1))
        for: 5m
        labels:
          severity: warning
          kind: ipsec_traffic
        annotations:
          summary: "No inbound traffic (rate(strongswan_sa_bytes_inbound[5m]) == 0)"
          description: "No inbound traffic detected. Check routing, firewall rules, and remote peer transmission."

      - alert: NoOutboundTraffic
        expr: sum by (ike_id, ike_name) ((rate(strongswan_sa_bytes_outbound[5m]) < 1) and on(child_id, ike_id) (strongswan_sa_state == 1)) == count by (ike_id, ike_name) ( (strongswan_sa_state == 1))
        for: 5m
        labels:
          severity: warning
          kind: ipsec_traffic
        annotations:
          summary: "No outbound traffic (rate(strongswan_sa_bytes_outbound[5m]) == 0)"
          description: "No outbound traffic detected. Verify local routing, policies, and application flow."

      - alert: NoRecentInbound
        expr: sum by (ike_id, ike_name) ((strongswan_sa_last_inbound_seconds > 60) and on(child_id, ike_id) (strongswan_sa_state == 1)) == count by (ike_id, ike_name) ( (strongswan_sa_state == 1)) 
        for: 2m
        labels:
          severity: warning
          kind: ipsec_traffic
        annotations:
          summary: "No recent inbound packets (>60s, strongswan_sa_last_inbound_seconds)"
          description: "Inbound traffic idle. Verify connectivity, remote activity, and firewall rules."

      - alert: NoRecentOutbound
        expr: sum by (ike_id, ike_name) ((strongswan_sa_last_outbound_seconds > 60) and on(child_id, ike_id) (strongswan_sa_state == 1)) == count by (ike_id, ike_name) ( (strongswan_sa_state == 1)) 
        for: 2m
        labels:
          severity: warning
          kind: ipsec_traffic
        annotations:
          summary: "No recent outbound packets (>60s, strongswan_sa_last_outbound_seconds)"
          description: "Outbound traffic idle. Check local applications and routing."

      - alert: PacketRateDrop
        expr: sum by (ike_id, ike_name) ((rate(strongswan_sa_packets_inbound[5m]) < 1) and on(child_id, ike_id) (strongswan_sa_state == 1)) == count by (ike_id, ike_name) ( (strongswan_sa_state == 1))
        for: 5m
        labels:
          severity: warning
          kind: ipsec_traffic
        annotations:
          summary: "Low packet rate (<1 pkt/s, strongswan_sa_packets_inbound)"
          description: "Inbound packet rate very low. Investigate congestion, drops, or application inactivity."

      - alert: WeakSAEncryption
        expr: strongswan_ike_state == 1 and strongswan_sa_encryption_keysize < 256
        for: 5m
        labels:
          severity: warning
          kind: ipsec_security_condition
        annotations:
          summary: "Weak SA encryption (<256 bits, strongswan_sa_encryption_keysize)"
          description: "Encryption strength below recommended level. Upgrade cipher suites to AES-256 or stronger."

      - alert: WeakIKEEncryption
        expr: strongswan_ike_state == 1 and strongswan_ike_encryption_keysize < 256
        for: 5m
        labels:
          severity: warning
          kind: ipsec_security_condition
        annotations:
          summary: "Weak IKE encryption (<256 bits, strongswan_ike_encryption_keysize)"
          description: "IKE encryption is weak. Update phase1 proposals to stronger algorithms."

      - alert: MissingIntegrityProtection
        expr: strongswan_sa_integrity_keysize == 0 and strongswan_sa_encryption_keysize < 256
        for: 5m
        labels:
          severity: critical
          kind: ipsec_security_condition
        annotations:
          summary: "Missing integrity protection (strongswan_sa_integrity_keysize == 0)"
          description: "Traffic may lack integrity protection. Enable authentication (e.g., SHA-256) and avoid weak encryption."

      - alert: WeakIKEIntegrity
        expr: strongswan_ike_integrity_keysize != 0 and strongswan_ike_integrity_keysize < 128
        for: 5m
        labels:
          severity: warning
          kind: ipsec_security_condition
        annotations:
          summary: "Weak IKE integrity (<128 bits, strongswan_ike_integrity_keysize)"
          description: "Integrity algorithm is weak. Upgrade to SHA-256 or better."

      - alert: LegacyIKEVersion
        expr: strongswan_ike_state == 1 and strongswan_ike_version != 2 
        for: 5m
        labels:
          severity: critical
          kind: ipsec_security_condition
        annotations:
          summary: "Legacy IKE version detected (strongswan_ike_version != 2)"
          description: "IKEv1 in use. Migrate to IKEv2 for improved security and stability."

      - alert: RekeyDisabled
        expr: strongswan_sa_rekey_second == 0
        for: 5m
        labels:
          severity: critical
          kind: ipsec_security_condition
        annotations:
          summary: "Rekey disabled (strongswan_sa_rekey_second == 0)"
          description: "No rekey configured. Enable rekeying to prevent stale sessions and security risks."

      - alert: IKERenewalDisabled
        expr: strongswan_ike_state == 1 and strongswan_ike_reauth_second == 0 and strongswan_ike_rekey_second == 0
        for: 5m
        labels:
          severity: warning
          kind: ipsec_security_condition
        annotations:
          summary: "IKE renewal disabled (reauth + rekey == 0)"
          description: "Both reauthentication and rekeying are disabled for a connection. The IKE SA will eventually expire without being renewed."

    inhibit_rules:
      - source_match:
          alertname: IKEDown
        target_match_re:
          alertname: ".*SA.*|No.*Traffic"
        equal: ["instance"]