{% for host in 
   (groups['virtual_machines'] | default([])) +
   (groups['baremetal_machines'] | default([]))  
%}
- targets:
    - {{ hostvars[host]['ansible_host'] }}:9100
  labels:
    instance: {{ host }}
{% if host in groups['baremetal_machines'] %}
    type: bare-metal
    role: {{ hostvars[host]['role'] }}
    location: {{ hostvars[host]['site'] }}
{% else %}
    type: virtual-machine
    location: {{ hostvars[host]["location"] | default(hostvars[host]["site"], true) | default("undefined") }}
{% endif %}
    environment: production
{% endfor %}